{
  "name": "Allwinner H700 (RG35XX, RG35XX Plus, TrimUI Smart Pro)",
  "soc": "Allwinner H700",
  "arch": "aarch64",
  "cpu": "Cortex-A53 x4",
  "gpu": "Mali-G31 MP2",
  "vpu": "Cedrus (H.264/H.265/VP8/VP9)",
  "kernel": "5.10+ (mainline) or 5.4 (vendor)",
  "ram": "1GB / 2GB LPDDR4",
  "display": "480x320 / 640x480",
  "drm_device": "/dev/dri/card0",
  "v4l2_decode": "/dev/video-decoder",
  "v4l2_encode": "/dev/video-encoder",
  "evdev_path": "/dev/input/",
  "uinput_path": "/dev/uinput",
  "alsa_card": "audiocodec",
  "alsa_pcm": "hw:0,0",
  "toolchain": "aarch64-linux-gnu",
  "cflags": "-march=armv8-a+crc -mtune=cortex-a53 -O3 -pipe -fomit-frame-pointer",
  "ldflags": "-Wl,--as-needed -Wl,-z,relro,-z,now",
  "cmake_flags": "-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_SYSTEM_PROCESSOR=aarch64",
  "pkg_config_path": "/usr/lib/aarch64-linux-gnu/pkgconfig",
  "sysroot": "/usr/aarch64-linux-gnu",
  "dependencies": [
    "libdrm-dev",
    "libgbm-dev",
    "libv4l-dev",
    "libudev-dev",
    "libalsa-dev",
    "libssl-dev",
    "libffi-dev",
    "libffi7",
    "zlib1g-dev"
  ],
  "backends": {
    "decode": "cedrus",
    "capture": "drm_kms",
    "input": "evdev_uinput",
    "audio": "alsa",
    "window": "drm_kms",
    "transport": "libdatachannel"
  },
  "notes": "Cedrus VPU requires kernel 5.10+ with sunxi-cedrus driver. Mainline kernel preferred. Cedrus driver at drivers/media/platform/sunxi/sunxi-cedrus.c"
}