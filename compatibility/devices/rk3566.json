{
  "name": "Rockchip RK3566 (RG556, RG Cube, Pi 5)",
  "soc": "Rockchip RK3566",
  "arch": "aarch64",
  "cpu": "Cortex-A55 x4",
  "gpu": "Mali-G52 MP2",
  "vpu": "RKVPU (RKMPP) - H.264/H.265/VP9 4K",
  "kernel": "5.10+ (mainline) or 5.10/6.1 (vendor)",
  "ram": "2GB / 4GB / 8GB LPDDR4",
  "display": "720p / 1080p",
  "drm_device": "/dev/dri/card0",
  "v4l2_decode": "/dev/video-decoder",
  "v4l2_encode": "/dev/video-encoder",
  "evdev_path": "/dev/input/",
  "uinput_path": "/dev/uinput",
  "alsa_card": "rockchipes8316",
  "alsa_pcm": "hw:0,0",
  "toolchain": "aarch64-linux-gnu",
  "cflags": "-march=armv8.2-a -mtune=cortex-a55 -O3 -pipe -fomit-frame-pointer",
  "ldflags": "-Wl,--as-needed -Wl,-z,relro,-z,now",
  "cmake_flags": "-DCMAKE_SYSTEM_NAME=Linux -DCMAKE_SYSTEM_PROCESSOR=aarch64",
  "pkg_config_path": "/usr/lib/aarch64-linux-gnu/pkgconfig",
  "sysroot": "/usr/aarch64-linux-gnu",
  "dependencies": [
    "libdrm-dev",
    "libgbm-dev",
    "libv4l-dev",
    "libmpp-dev",
    "librockchip-mpp-dev",
    "librockchip-vpu-dev",
    "libudev-dev",
    "libalsa-dev",
    "libssl-dev",
    "libffi-dev",
    "zlib1g-dev"
  ],
  "backends": {
    "decode": "rkmp_px",
    "capture": "drm_kms",
    "input": "evdev_uinput",
    "audio": "alsa",
    "window": "drm_kms",
    "transport": "libdatachannel"
  },
  "notes": "RKMPP requires librkppm and librockchip-mpp. Kernel needs CONFIG_VIDEO_ROCKCHIP_VPU=y."
}