{
  "name": "Generic x86_64 Linux (Desktop, Steam Deck, handheld PCs)",
  "soc": "Any x86_64 (Intel/AMD)",
  "arch": "x86_64",
  "cpu": "Any modern",
  "gpu": "Intel iGPU / AMD RDNA / NVIDIA",
  "vpu": "Intel QuickSync / AMD VCN / NVENC/NVDEC",
  "kernel": "5.15+ (modern distro)",
  "ram": "4GB+",
  "display": "Any",
  "drm_device": "/dev/dri/card0",
  "v4l2_decode": "/dev/video*",
  "v4l2_encode": "/dev/video*",
  "evdev_path": "/dev/input/",
  "uinput_path": "/dev/uinput",
  "alsa_card": "default",
  "alsa_pcm": "default",
  "toolchain": "native",
  "cflags": "-march=native -O3 -pipe -fomit-frame-pointer",
  "ldflags": "-Wl,--as-needed -Wl,-z,relro,-z,now",
  "cmake_flags": "",
  "dependencies": [
    "libdrm-dev",
    "libgbm-dev",
    "libva-dev",
    "libvdpau-dev",
    "libv4l-dev",
    "libudev-dev",
    "libalsa-dev",
    "libssl-dev",
    "libffi-dev",
    "zlib1g-dev",
    "meson",
    "ninja-build"
  ],
  "backends": {
    "decode": "vaapi",
    "capture": "pipewire",
    "input": "evdev_uinput",
    "audio": "pipewire",
    "window": "wayland",
    "transport": "libdatachannel"
  },
  "notes": "VA-API preferred for Intel/AMD. NVENC/NVDEC via CUDA if NVIDIA GPU present."
}