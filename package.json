{
  "name": "NearsecTogether",
  "version": "2.0.1",
  "author": "Fame <support@cutefame.net>",
  "description": "Browser-based game streaming host",
  "main": "electron-main.js",
  "scripts": {
    "start": "node src/scripts/server.js",
    "electron": "electron .",
    "dev": "electron . --dev",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "dist": "electron-builder --publish always",
    "dist:win": "electron-builder --win --publish always",
    "dist:mac": "electron-builder --mac --publish always",
    "dist:linux": "electron-builder --linux --publish always"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.0",
    "kill-port": "latest",
    "open": "latest",
    "play-sound": "latest",
    "pusher-js": "^8.5.0",
    "which": "latest",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "wrangler": "^4.90.0"
  },
  "build": {
    "appId": "com.nearsectogether.app",
    "productName": "NearsecTogether",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github"
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "!/.env",
      "**/*",
      "!website",
      "!src/docs",
      "!**/*.md",
      "!.github",
      "!kbm_presets",
      "!.flatpak-builder"
    ],
    "asarUnpack": [
      "src/sidecar/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/NearsecTogether.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/NearsecTogether.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/NearsecTogether.png",
      "category": "Network"
    }
  }
}
